generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Guest {
  id        String   @id @default(cuid())
  name      String
  email     String?
  attending Boolean  @default(true)
  message   String?
  createdAt DateTime @default(now())
}